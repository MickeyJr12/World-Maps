{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "scrollbar-width",
          "backdrop-filter",
          "scrollbar-width: none",
          "animation-timeline",
          "animation-range",
          "scrollbar-color",
          "scrollbar-width: thin",
          "animation-timeline: view()",
          "-webkit-overflow-scrolling"
        ]
      }
    ],
    "no-inline-styles": "off",
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ],
    "meta-viewport": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "apple-touch-icons": "off"
  }
}